@startuml
'https://plantuml.com/class-diagram

class Cliente{
    -rut: String
    -nombre: String
    -apellidoPaterno: String
    -apellidoMaterno: String
    -nombreUsuario: String
    -contrasenia: String
    -categoriaSocio: String
    +Cliente(rut: String, nombre: String, apellidoPaterno: String, apellidoMaterno: String,
    nombreUsuario: String, contrasenia: String, categoriaSocio: String)
    +get's()
    +set's()
}

class ContenedorClientes{
    -clientes: Cliente[]
    -cantMaxClientes: int
    -cantActualCliente: int
    +ContenedorClientes(cantMax: int)
    +agregarCliente(cliente: Cliente): boolean
    +obtenerCliente(posicion: int): Cliente
    +buscarClientePorRut(rut: String): int
    +buscarClientePorNombre(nombreUsuario: String): int
    +puedeJugar(categoria: String, jugadasHoy: int): boolean
    +puedeSubirCategoria(categoriaActual: String, sesionesGanadas: int): boolean
    +categoriaSiguiente(categoriaActual): String
    +get's()
}

ContenedorClientes"1"o-->"*"Cliente: almacena
Cliente "1" --> "1" ContenedorJugadas: acumula
Cliente "1" --> "1" Mesa: juega

class Mesa{
    -id: int
    -tipoJuego: String
    -descripcion: String
    -apuestaMin: int
    -apuestaMax: int
    -estado: boolean
    +Mesa(id: int, tipoJuego: String, descripcion: String, apuestaMin: int,
    apuestaMax: int, estado: boolean)
    +get's()
    +set's()
}

class ContenedorMesas{
    -mesas: Mesa[]
    -cantMaxMesa: int
    -cantActualMesa: int
    +ContenedorMesa(cantMax: int)
    +agregarMesa(mesa: Mesa): boolean
    +obtenerMesa(posicion: int): Mesa
    +obtenerMesaPorId(id: int): Mesa
    +get's()
    }
ContenedorMesas"1"o->"*"Mesa: almacena

class Jugada{
    -fechaJugada: String
    -fechaHoy: LocalDateTime
    -apuesta: int
    -resultado: String
    -cliente: Cliente
    -mesa: Mesa
    -categoriaEnJugada: String
    +Jugada(cliente: Cliente, mesa: Mesa, fechaJugada: String, apuesta: int: resultado: String)
    +get's()
    +set's()
}

class ContenedorJugadas{
    -jugadas: Jugada[]
    -cantMaxJugada: int
    -cantActualJugada: int
    +ContenedorJugadas(cantMax: int)
    +agregarJugada(jugada: Jugada): boolean
    +ordenarJugadas(): void
    +obtenerJugada(posicion: int): Jugada
    +contarPartidasGanadas(rutCliente: String, categoriaActual: String): int
    +get's()
}
ContenedorJugadas"1"o-->"*"Jugada: almacena

class SistemaCasinoImpl{
    -contenedorClientes: ContenedorClientes
    -contenedorMesas: ContenedorMesas
    -contenedorJugadas: ContenedorJugadas
    +SistemaCasinoImpl()
}

SistemaCasinoImpl"1"-->"1"ContenedorClientes: posee
SistemaCasinoImpl"1"-->"1"ContenedorMesas: posee
SistemaCasinoImpl"1"-->"1"ContenedorJugadas: posee
SistemaCasinoImpl"1"..|>"1"SistemaCasino: implementa

interface SistemaCasino{
    +cargaDeDatos(): void
    +datosCargados(): boolean
    +registroNuevoCliente()
    +iniciarSesion(nombreUsuario: String, contrasenia: String): boolean
    +desplegarMesaDisponible(): void
    +registrarSesionJuego(nombreUsuario: String, jugada: Jugada): void
    +comprobanteSesionJuego(cliente: Cliente, jugada: Jugada): void
    +consultarHistorial(nombreUsuario: String): void
    +accesoAdministrarMesas(nombreUsuario: String): boolean
    +cambiarEstadoMesa(): void
    +crearYAgregarMesa(): void
    +verDatosPersonales(nombreUsuario: String): void
    +subirCategoria(nombreUsuario: String): void
    +cambiarContraseña(nombreUsuario: String, contraseniaActual: String): boolean
    +desplegarMesas(): void
    +desplegarEstadistica(): void
    +subirDatos(): void
}
@enduml